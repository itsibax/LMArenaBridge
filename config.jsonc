{
  // Version number used by the auto-update checker. Do not modify manually.
  "version": "2.7.6",

  // --- Session settings ---
  // Current LMArena session ID (run id_updater.py to refresh automatically).
  "session_id": "cebc557a-3f35-4794-beaf-6e33d947e0cd",

  // Current message ID for the active session (also updated by id_updater.py).
  "message_id": "562414bc-0ea8-412a-bd15-8ec1cc61f4af",

  // --- ID updater metadata ---
  // Last mode chosen in id_updater.py ('direct_chat' or 'battle').
  "id_updater_last_mode": "battle",
  // When using battle mode, which assistant (A or B) should receive the new IDs.
  "id_updater_battle_target": "B",

  // --- Update settings ---
  // Toggle automatic update checks at startup.
  "enable_auto_update": true,

  // --- Feature toggles ---

  // Inject an empty user message to help bypass sensitive-word screening.
  "bypass_enabled": true,

  // Tavern Mode merges system prompts for SillyTavern-style clients.
  "tavern_mode_enabled": false,

  // --- File bed settings ---
  // Enable to upload multimedia attachments to the auxiliary file-bed server
  // and replace base64 payloads with public URLs.
  "file_bed_enabled": false,

  // Upload endpoint of the file-bed server (use escaped // for compatibility).
  "file_bed_upload_url": "http:\/\/127.0.0.1:5180/upload",

  // API key for the file-bed server (if configured in file_bed_server/main.py).
  "file_bed_api_key": "your_secret_api_key",

  // --- Model mapping options ---

  // When true, fall back to the global session/message IDs if a model mapping
  // is missing in model_endpoint_map.json; otherwise raise an error.
  "use_default_ids_if_mapping_not_found": true,

  // --- Advanced settings ---

  // Streaming timeout (seconds). Increase if your network is slow or models
  // regularly take longer to respond.
  "stream_response_timeout_seconds": 360,

  // --- Auto-restart settings ---

  // Enable automatic restart when the server has been idle beyond the timeout.
  "enable_idle_restart": true,

  // Idle restart timeout in seconds. Set to -1 to disable even if the switch is true.
  "idle_restart_timeout_seconds": -1,

  // --- Security ---

  // API key required for /v1/chat/completions requests (use Authorization header).
  "api_key": ""
}
